<view class="page">
  <view class="header">
    <text class="title">Crypto POC</text>
    <text class="subtitle">AES-GCM cross-platform verification</text>
  </view>
  <view class="loading" tt:if="{{!ready}}"><text>Running...</text></view>
  <view class="import-error" tt:if="{{importError}}"><text class="err-text">{{importError}}</text></view>
  <view class="debug" tt:if="{{debugInfo}}"><text class="debug-text">{{debugInfo}}</text></view>
  <view class="summary" tt:if="{{ready && !importError}}">
    <text class="score">{{passed}} / {{passed + failed}} passed</text>
    <text class="verdict {{failed === 0 ? 'ok' : 'fail'}}">{{failed === 0 ? '‚ú?All pass' : '‚ù?Some failed'}}</text>
  </view>
  <view class="results" tt:if="{{ready && !importError}}">
    <view class="test-item {{item.passed ? 'pass' : 'fail'}}" tt:for="{{results}}" tt:key="name">
      <view class="test-head"><text class="test-icon">{{item.passed ? '‚ú? : '‚ù?}}</text><text class="test-name">{{item.name}}</text></view>
      <text class="test-detail">{{item.detail}}</text>
    </view>
  </view>
</view>
