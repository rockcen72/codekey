.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--ck-bg);
}

/* â”€â”€ Topbar â”€â”€ */

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx 12rpx;
}
.topbar-left { display: flex; flex-direction: column; gap: 2rpx; }
.brand { display: block; font-size: 40rpx; font-weight: 800; color: var(--ck-text); letter-spacing: -0.5rpx; }
.brand-sub { display: block; font-size: 22rpx; color: var(--ck-subtle); }
.top-actions { display: flex; align-items: center; gap: 10rpx; }
.conn-pill { height: 44rpx; display: flex; align-items: center; gap: 6rpx; padding: 0 14rpx; border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-full); background: var(--ck-surface); font-size: 22rpx; color: var(--ck-muted); }
.conn-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: var(--ck-subtle); transition: background 140ms ease; }
.conn-pill.online .conn-dot { background: var(--ck-success); }
.icon-btn-wrap { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; border-radius: var(--ck-radius-full); border: 1rpx solid var(--ck-border); background: var(--ck-surface); }
.icon-btn-wrap:active { background: var(--ck-bg); }
.icon-btn { font-size: 36rpx; color: var(--ck-muted); line-height: 1; }

/* â”€â”€ Subscription pill (top bar, P4.1) â”€â”€
   Shape mirrors .conn-pill; tappable â†?opens settings.
   6 visual variants driven by subQuotaState + subTier + isExpiringSoon:
     paid / trial      â†?blue tint  (.sub-pill-tier-paid, .sub-pill-tier-trial)
     paid + <=3d left  â†?amber      (.sub-pill-expiring)  P4.1.2
     free + normal     â†?neutral    (.sub-pill-normal, .sub-pill-tier-free)
     free + approaching â†?amber     (.sub-pill-approaching)
     free + exhausted  â†?red        (.sub-pill-exhausted) */
.sub-pill {
  height: 44rpx;
  display: flex;
  align-items: center;
  padding: 0 14rpx;
  border-radius: var(--ck-radius-full);
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sub-pill-tier-paid,
.sub-pill-tier-trial { color: var(--ck-primary); background: rgba(37, 99, 235, 0.08); border: 1rpx solid rgba(37, 99, 235, 0.25); }
.sub-pill-tier-free,
.sub-pill-normal { color: var(--ck-muted); background: var(--ck-surface); border: 1rpx solid var(--ck-border); }
.sub-pill-approaching { color: var(--ck-warning); background: rgba(217, 119, 6, 0.08); border: 1rpx solid rgba(217, 119, 6, 0.30); }
.sub-pill-expiring { color: var(--ck-warning); background: rgba(217, 119, 6, 0.08); border: 1rpx solid rgba(217, 119, 6, 0.30); font-weight: 700; }
.sub-pill-exhausted { color: var(--ck-danger); background: rgba(220, 38, 38, 0.08); border: 1rpx solid rgba(220, 38, 38, 0.30); }

/* â”€â”€ Agent tabs â”€â”€ */

.tabs-scroll { padding: 4rpx 28rpx 12rpx; white-space: nowrap; }
.tabs { display: flex; gap: 8rpx; }
.tab {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 22rpx;
  border-radius: var(--ck-radius-full);
  background: var(--ck-surface);
  border: 1rpx solid var(--ck-border);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ck-muted);
  transition: all 140ms ease;
}
.tab:active { opacity: .7; }
.tab.active {
  background: var(--ck-primary);
  border-color: var(--ck-primary);
  color: #fff;
}

/* â”€â”€ Unpaired banner â”€â”€ */

.unpaired-banner {
  display: flex;
  align-items: center;
  margin: 0 24rpx 12rpx;
  padding: 20rpx 24rpx;
  background: #fff8e6;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}
.banner-stripe {
  width: 6rpx; height: 56rpx;
  background: #f5b400; border-radius: 3rpx;
  margin-right: 20rpx; flex-shrink: 0;
}
.banner-body { flex: 1; display: flex; flex-direction: column; min-width: 0; }
.banner-title { font-size: 28rpx; color: #4a3a00; font-weight: 600; }
.banner-desc { font-size: 24rpx; color: #806a2c; margin-top: 4rpx; }
.banner-cta { font-size: 26rpx; color: #c08a00; padding-left: 20rpx; flex-shrink: 0; }

/* â”€â”€ Metrics chips â”€â”€ */

.metrics-row { display: flex; gap: 10rpx; padding: 0 28rpx 14rpx; }
.metric-chip { display: flex; align-items: center; gap: 6rpx; height: 38rpx; padding: 0 14rpx; border-radius: var(--ck-radius-full); background: var(--ck-surface); border: 1rpx solid var(--ck-border); font-size: 20rpx; line-height: 38rpx; color: var(--ck-muted); }
.metric-chip.danger { border-color: #fecaca; background: #fef2f2; color: var(--ck-danger); }
.metric-dot { width: 8rpx; height: 8rpx; border-radius: 50%; }
.metric-dot.active { background: var(--ck-success); }
.metric-dot.pending { background: var(--ck-danger); }

/* â”€â”€ Session list â”€â”€ */

.list { flex: 1; padding: 0 28rpx 28rpx; }
.swipe-wrap { overflow: hidden; margin-bottom: 14rpx; border-radius: var(--ck-radius-md); }
.swipe-inner { display: flex; transition: transform 200ms ease; }
.swipe-inner.swiped { transform: translateX(-140rpx); }

/* â”€â”€ Session card â”€â”€ */

.session-card { display: flex; align-items: stretch; flex-shrink: 0; width: 100%; border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-md); background: var(--ck-surface); box-shadow: 0 2rpx 8rpx rgba(28,25,23,0.04); transition: box-shadow 140ms ease, transform 140ms ease, border-color 0.2s ease; overflow: hidden; }
.session-card:active { box-shadow: 0 4rpx 12rpx rgba(28,25,23,0.08); transform: translateY(-1rpx); }
.session-card.connected { border-color: var(--ck-border); }
.session-card.connected.agent-claude { border-color: rgba(234,88,12,0.35); }
.session-card.connected.agent-codex { border-color: rgba(34,197,94,0.35); }
.session-card.connected.agent-opencode { border-color: rgba(92,156,245,0.35); }
.conn-bar { width: 10rpx; flex-shrink: 0; background: var(--ck-border); transition: background 200ms ease; }
.conn-bar.agent-claude { background: #ea580c; }
.conn-bar.agent-codex { background: #22c55e; }
.conn-bar.agent-opencode { background: #5c9cf5; }
.conn-bar.agent-unknown { background: var(--ck-border); }

/* â”€â”€ Card body â”€â”€ */

.card-body { flex: 1; min-width: 0; padding: 20rpx 20rpx 20rpx 16rpx; }
.card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10rpx; }
.card-title-row { display: flex; align-items: center; gap: 8rpx; min-width: 0; flex: 1; }
.session-title { font-size: 30rpx; font-weight: 700; color: var(--ck-text); flex: 1; min-width: 0; }
.title-sweep-host {
  flex: 1; min-width: 0; padding: 2rpx 6rpx; margin: -2rpx -6rpx;
  border-radius: 4rpx; overflow: hidden; position: relative;
}
.title-sweep-bar {
  position: absolute; top: 0; bottom: 0; left: 0; width: 60%;
  background: linear-gradient(90deg, transparent 0%, rgba(128,128,128,0.22) 50%, transparent 100%);
  transform: translateX(-100%);
  pointer-events: none;
}
.title-sweep-host.is-sweeping .title-sweep-bar {
  animation: titleSweep 1.2s ease-in-out 1;
}
.agent-chip { font-size: 18rpx; font-weight: 500; padding: 2rpx 12rpx; border-radius: var(--ck-radius-full); flex-shrink: 0; }
.agent-chip.agent-claude { color: #ea580c; background: rgba(234,88,12,0.08); }
.agent-chip.agent-codex { color: #22c55e; background: rgba(34,197,94,0.08); }
.agent-chip.agent-opencode { color: #5c9cf5; background: rgba(92,156,245,0.08); }
.agent-chip.agent-unknown { color: var(--ck-muted); background: var(--ck-surface); border: 1rpx solid var(--ck-border); }
.card-time-wrap { display: flex; align-items: center; gap: 6rpx; flex-shrink: 0; }
.session-time { font-size: 20rpx; color: var(--ck-subtle); white-space: nowrap; }
.session-subtitle { display: block; margin-top: 6rpx; font-size: 24rpx; color: var(--ck-muted); }
@keyframes titleSweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(220%); } }
.card-footer { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; }
.session-id { font-size: 18rpx; color: var(--ck-subtle); }

/* â”€â”€ Pending badge â”€â”€ */

.pending-badge { margin-left: auto; min-width: 36rpx; height: 36rpx; padding: 0 8rpx; display: flex; align-items: center; justify-content: center; border-radius: 36rpx; background: #e53e3e; box-shadow: 0 2rpx 6rpx rgba(229,62,62,0.35); }
.pending-badge-num { font-size: 20rpx; font-weight: 700; color: #fff; line-height: 1; }

/* â”€â”€ Delete area â”€â”€ */

.delete-area { flex-shrink: 0; width: 140rpx; display: flex; align-items: center; justify-content: center; background: #fef2f2; border: 1rpx solid #fecaca; border-radius: 0 var(--ck-radius-md) var(--ck-radius-md) 0; cursor: pointer; }
.delete-area:active { background: #fee2e2; }
.delete-text { color: #dc2626; font-size: 26rpx; font-weight: 600; }

/* â”€â”€ Empty state â”€â”€ */

.empty { padding: 200rpx 40rpx 0; text-align: center; }
.empty-icon { display: block; font-size: 72rpx; color: var(--ck-border); margin-bottom: 24rpx; }
.empty-title { display: block; font-size: 32rpx; font-weight: 800; color: var(--ck-text); }
.empty-text { display: block; margin-top: 10rpx; font-size: 26rpx; color: var(--ck-muted); line-height: 1.6; }
