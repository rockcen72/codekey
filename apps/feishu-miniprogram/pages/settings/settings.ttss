.container { display: flex; flex-direction: column; min-height: 100vh; background: var(--ck-bg); }
.header { display: flex; align-items: center; padding: 28rpx 32rpx 14rpx; border-bottom: 1rpx solid var(--ck-border); background: var(--ck-surface); }
.back { font-size: 28rpx; color: var(--ck-primary); margin-right: 16rpx; font-weight: 600; }
.title { font-size: 36rpx; font-weight: 800; color: var(--ck-text); }
.section { padding: 24rpx 32rpx; }
.section-title { font-size: 24rpx; font-weight: 700; color: var(--ck-muted); margin-bottom: 14rpx; display: block; text-transform: uppercase; letter-spacing: 1rpx; }
.info-row { display: flex; align-items: center; padding: 14rpx 0; }
.info-row-warning .label { color: var(--ck-warning); font-weight: 700; }
.info-row-warning .value { color: var(--ck-warning); font-weight: 700; }
.label { font-size: 26rpx; color: var(--ck-muted); width: 140rpx; flex-shrink: 0; }
.value { font-size: 28rpx; color: var(--ck-text); flex: 1; }
.value.code { font-family: monospace; font-size: 24rpx; }
.value.input { border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-sm); padding: 8rpx 12rpx; font-size: 24rpx; background: var(--ck-bg); }
.copy-btn { font-size: 22rpx; color: var(--ck-primary); font-weight: 600; padding: 4rpx 12rpx; border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-sm); }
.pair-section { padding-bottom: 8rpx; }
.scan-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  margin-bottom: 20rpx;
  border-radius: var(--ck-radius-md);
  background: var(--ck-primary); color: #fff;
  font-size: 28rpx; font-weight: 700;
  text-align: center;
}
.scan-btn::after { border: none; }
.manual-row { display: flex; align-items: center; gap: 12rpx; }
.manual-input {
  flex: 1; height: 72rpx; padding: 0 16rpx;
  border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-sm);
  background: var(--ck-bg); font-size: 26rpx; font-family: monospace;
  letter-spacing: 2rpx; text-transform: uppercase;
}
.manual-btn {
  flex: 0 0 112rpx; height: 72rpx; line-height: 72rpx;
  border-radius: var(--ck-radius-sm);
  background: var(--ck-primary); color: #fff;
  font-size: 26rpx; font-weight: 600;
  padding: 0; margin: 0;
}
.manual-btn::after { border: none; }
.pair-hint { margin-top: 16rpx; }
.pair-hint text { font-size: 22rpx; color: var(--ck-muted); line-height: 1.5; }

.unbind-btn { margin-top: 20rpx; width: 100%; height: 80rpx; line-height: 80rpx; border-radius: var(--ck-radius-md); background: #fef2f2; color: var(--ck-danger); font-size: 28rpx; font-weight: 700; border: 1rpx solid #fecaca; text-align: center; }
.unbind-btn:active { background: #fee2e2; }
.redeem-row { display: flex; align-items: center; gap: 12rpx; margin-top: 16rpx; }
.redeem-input { flex: 1 1 0; width: 0; height: 72rpx; padding: 0 16rpx; border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-sm); background: var(--ck-bg); font-size: 26rpx; font-family: monospace; letter-spacing: 1rpx; min-width: 0; }
.redeem-btn { display: flex; align-items: center; justify-content: center; flex: 0 0 112rpx; width: 112rpx; max-width: 112rpx; min-width: 112rpx; height: 72rpx; line-height: 72rpx; font-size: 26rpx; font-weight: 600; border-radius: var(--ck-radius-sm); background: var(--ck-primary); color: #fff; padding: 0; margin: 0; }
.redeem-btn::after { border: none; }
.redeem-btn[disabled] { opacity: 0.5; }
.quota-card { margin-top: 18rpx; padding: 16rpx 18rpx; background: var(--ck-surface); border: 1rpx solid var(--ck-border); border-radius: var(--ck-radius-md); }
.quota-bar { width: 100%; height: 14rpx; background: var(--ck-bg); border-radius: 7rpx; overflow: hidden; }
.quota-fill { height: 100%; border-radius: 7rpx; transition: width 200ms ease, background 200ms ease; }
.quota-normal { background: var(--ck-primary); }
.quota-approaching { background: var(--ck-warning); }
.quota-exhausted { background: var(--ck-danger); }
.quota-status { display: block; margin-top: 10rpx; font-size: 24rpx; font-weight: 600; }
.quota-status-normal { color: var(--ck-muted); }
.quota-status-approaching { color: var(--ck-warning); }
.quota-status-exhausted { color: var(--ck-danger); }
.about { padding-bottom: 40rpx; }
.about-text { font-size: 26rpx; color: var(--ck-muted); display: block; margin-bottom: 8rpx; }
.about-link { display: inline-block; margin-top: 12rpx; font-size: 26rpx; color: var(--ck-primary); font-weight: 600; }
.e2e-ok { color: #16a34a; font-weight: 700; }
.e2e-missing { color: var(--ck-muted); }
.e2e-stale { color: #d97706; font-weight: 700; }
.e2e-hint { margin-top: 8rpx; font-size: 22rpx; line-height: 1.5; padding: 8rpx 0; }
.e2e-hint.stale-hint { color: #92400e; }
