{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "codekey-telegram-miniapp",
  "compatibility_date": "2026-06-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "directory": "dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
