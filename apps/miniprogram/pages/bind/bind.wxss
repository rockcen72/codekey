.container { display: flex; flex-direction: column; align-items: center; padding: 200rpx 40rpx 0; }
.loading-icon { width: 80rpx; height: 80rpx; border: 6rpx solid #07c160; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 32rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.success-icon { width: 120rpx; height: 120rpx; line-height: 120rpx; text-align: center; background: #07c160; color: #fff; border-radius: 50%; font-size: 32rpx; font-weight: 700; margin-bottom: 32rpx; }
.fail-icon { width: 120rpx; height: 120rpx; line-height: 120rpx; text-align: center; background: #e64340; color: #fff; border-radius: 50%; font-size: 32rpx; font-weight: 700; margin-bottom: 32rpx; }
.status-text { font-size: 36rpx; font-weight: 600; margin-bottom: 16rpx; }
.code-display { font-size: 28rpx; color: #999; font-family: monospace; }
.hint-text { font-size: 28rpx; color: #999; }
.error-msg { font-size: 28rpx; color: #e64340; text-align: center; margin: 16rpx 0 48rpx; }
.retry-btn { width: 400rpx; height: 80rpx; line-height: 80rpx; background: #07c160; color: #fff; border-radius: 40rpx; font-size: 30rpx; }
