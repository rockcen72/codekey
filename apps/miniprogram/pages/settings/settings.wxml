<view class="container">
  <view class="header">
    <text class="back" bindtap="goBack">返回</text>
    <text class="title">设置</text>
  </view>

  <view class="section">
    <text class="section-title">已绑定设备</text>
    <view class="info-row">
      <text class="label">设备 ID</text>
      <text class="value code">{{deviceId || '未绑定'}}</text>
      <text class="copy-btn" wx:if="{{deviceId}}" bindtap="copyDeviceId">复制</text>
    </view>
    <view class="info-row">
      <text class="label">服务器</text>
      <text class="value">{{serverUrl}}</text>
    </view>
  </view>

  <view class="section">
    <button class="unbind-btn" bindtap="unbindDevice">解绑设备</button>
  </view>

  <view class="section about">
    <text class="section-title">关于</text>
    <text class="about-text">CodeKey v0.1.0</text>
    <text class="about-text">AI 远程控制工具</text>
  </view>
</view>
