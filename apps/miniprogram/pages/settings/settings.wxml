<view class="container">
  <view class="header">
    <text class="back" bindtap="goBack">返回</text>
    <text class="title">设置</text>
  </view>

  <view class="section" wx:if="{{loaded}}">
    <text class="section-title">订阅</text>
    <view class="info-row info-row-warning" wx:if="{{tier === 'paid' && isExpiringSoon}}">
      <text class="label">Pro 即将到期</text>
      <text class="value">还剩 {{daysRemaining}} 天 · 续期使用下方兑换码</text>
    </view>
    <view class="info-row" wx:elif="{{tier === 'paid'}}">
      <text class="label">Pro 已开通</text>
      <text class="value">有效期至 {{expiresAt}}</text>
    </view>
    <view class="info-row" wx:elif="{{tier === 'trial'}}">
      <text class="label">Pro 试用中</text>
      <text class="value" wx:if="{{daysRemaining != null && daysRemaining > 0}}">还剩 {{daysRemaining}} 天</text>
      <text class="value" wx:elif="{{daysRemaining === 0}}">今天到期</text>
      <text class="value" wx:else>{{expiresAt}} 到期</text>
    </view>
    <view class="info-row" wx:elif="{{tier === 'free'}}">
      <text class="label">当前为 Free</text>
      <text class="value" wx:if="{{usage}}">本月已用 {{usage.used}}/{{usage.limit}} 次</text>
      <text class="value" wx:else>本月初级版</text>
    </view>
    <view class="info-row" wx:elif="{{tier === 'unauthenticated'}}">
      <text class="label">未登录</text>
      <text class="value">配对设备后查看</text>
    </view>
    <view class="info-row" wx:elif="{{tier === 'load_failed'}}">
      <text class="label">加载失败</text>
      <text class="value" bindtap="refreshSubscription">点击重试</text>
    </view>

    <!-- Quota progress bar (free tier only). Hidden for paid/trial
         since the server returns usage=null for those tiers. -->
    <view class="quota-card" wx:if="{{quotaState !== 'hidden'}}">
      <view class="quota-bar">
        <view class="quota-fill quota-{{quotaState}}" style="width: {{quotaPercent}}%"></view>
      </view>
      <text class="quota-status quota-status-{{quotaState}}">
        <text wx:if="{{quotaState === 'approaching'}}">接近额度上限 (≥80%)</text>
        <text wx:elif="{{quotaState === 'exhausted'}}">本月 {{usage.limit}} 次审批已用完</text>
        <text wx:else>本月已用 {{usage.used}}/{{usage.limit}} 次</text>
      </text>
    </view>

    <view class="redeem-row">
      <input
        class="redeem-input"
        placeholder="输入兑换码 (CK-XXXX-XXXX-XXXX)"
        value="{{redeemInput}}"
        bindinput="onRedeemInput"
        maxlength="20"
        confirm-type="done"
      />
      <button
        class="redeem-btn"
        bindtap="submitRedeem"
        loading="{{redeemBusy}}"
        disabled="{{redeemBusy || !redeemInput || tier === 'unauthenticated'}}"
      >兑换</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">已绑定设备</text>
    <view class="info-row">
      <text class="label">设备 ID</text>
      <text class="value code">{{deviceId || '未绑定'}}</text>
      <text class="copy-btn" wx:if="{{deviceId}}" bindtap="copyDeviceId">复制</text>
    </view>
  </view>

  <view class="section">
    <button class="unbind-btn" bindtap="unbindDevice">解绑设备</button>
  </view>

  <view class="section">
    <text class="section-title">端到端加密</text>
    <view class="info-row">
      <text class="label">加密状态</text>
      <text wx:if="{{e2eStatus === 'stale'}}" class="value e2e-stale">需要重新配对</text>
      <text wx:elif="{{e2eStatus === 'enabled'}}" class="value e2e-ok">已启用</text>
      <text wx:else class="value e2e-missing">未启用</text>
    </view>
    <view wx:if="{{e2eStatus === 'stale'}}" class="e2e-hint stale-hint">
      <text>桌面端密钥已更新，请在电脑上重新配对手机以继续使用加密功能。</text>
    </view>
  </view>

  <view class="section about">
    <text class="section-title">关于</text>
    <text class="about-text">CodeKey v1.1.6</text>
    <text class="about-text">AI 远程控制工具</text>
  </view>
</view>
