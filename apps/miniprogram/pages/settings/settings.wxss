.container { display: flex; flex-direction: column; min-height: 100vh; }
.header { display: flex; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid #eee; }
.back { font-size: 28rpx; color: #07c160; margin-right: 16rpx; }
.title { font-size: 36rpx; font-weight: 700; }
.section { padding: 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.section-title { font-size: 28rpx; color: #999; margin-bottom: 16rpx; display: block; }
.info-row { display: flex; align-items: center; padding: 12rpx 0; }
.label { font-size: 28rpx; color: #666; width: 140rpx; }
.value { font-size: 28rpx; color: #333; flex: 1; }
.value.code { font-family: monospace; font-size: 24rpx; }
.copy-btn { font-size: 24rpx; color: #07c160; padding: 4rpx 12rpx; }
.unbind-btn { margin-top: 16rpx; background: #e64340; color: #fff; border-radius: 12rpx; height: 80rpx; line-height: 80rpx; font-size: 30rpx; }
.about { }
.about-text { font-size: 26rpx; color: #999; display: block; margin-bottom: 8rpx; }
