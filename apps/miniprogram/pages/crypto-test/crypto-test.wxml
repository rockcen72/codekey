<view class="page">
  <view class="header">
    <text class="title">Crypto POC</text>
    <text class="subtitle">AES-GCM runtime diagnostic</text>
  </view>
  <view class="loading" wx:if="{{!ready}}">
    <text>Running...</text>
  </view>
  <view class="output" wx:if="{{ready}}">
    <text class="line" wx:for="{{lines}}" wx:key="*this">{{item}}</text>
  </view>
</view>
