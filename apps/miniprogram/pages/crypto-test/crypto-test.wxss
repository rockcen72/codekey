.page { padding: 16px; background: #f5f0eb; min-height: 100vh; }
.header { margin-bottom: 16px; }
.title { display: block; font-size: 22px; font-weight: 700; color: #222; }
.subtitle { display: block; font-size: 13px; color: #888; margin-top: 4px; }
.loading { text-align: center; padding: 40px; color: #888; font-size: 14px; }
.import-error { padding: 12px; background: #fef2f2; border-radius: 6px; margin-bottom: 12px; }
.err-text { font-size: 12px; color: #cf222e; word-break: break-all; }
.debug { padding: 8px 12px; margin-bottom: 12px; background: #fff3cd; border-radius: 6px; }
.debug-text { font-size: 11px; color: #856404; word-break: break-all; }
.summary { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: #fff; border-radius: 8px; margin-bottom: 16px; }
.score { font-size: 16px; font-weight: 700; color: #333; }
.verdict { font-size: 14px; }
.verdict.ok { color: #2da44e; }
.verdict.fail { color: #cf222e; }
.test-item { padding: 10px 12px; margin-bottom: 8px; background: #fff; border-radius: 6px; border-left: 3px solid #d0d7de; }
.test-item.pass { border-left-color: #2da44e; }
.test-item.fail { border-left-color: #cf222e; }
.test-head { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.test-icon { font-size: 14px; }
.test-name { font-size: 14px; font-weight: 600; color: #333; }
.test-detail { display: block; font-size: 11px; color: #888; word-break: break-all; }
