<view class="container">
  <view class="logo">CodeKey</view>
  <text class="subtitle">AI 远程控制</text>
  <text class="desc">扫描电脑终端的配对码，连接你的 AI 代理</text>

  <button class="scan-btn" wx:if="{{canScan}}" bindtap="startScan">
    扫码绑定
  </button>

  <view class="manual-section">
    <text class="manual-toggle" bindtap="toggleManualInput">
      {{showManualInput ? '取消' : '手动输入配对码'}}
    </text>

    <view class="manual-input-area" wx:if="{{showManualInput}}">
      <input class="code-input" placeholder="例如 ABC12345" maxlength="8"
             model:value="{{manualCode}}" />
      <button class="confirm-btn" bindtap="confirmManualCode">绑定</button>
    </view>
  </view>

  <view class="hint">
    <text>在电脑上运行 "codekey login" 获取配对码</text>
  </view>
</view>
