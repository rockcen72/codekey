.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 0;
}
.logo {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--ck-primary);
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 32rpx;
  color: var(--ck-muted);
  margin-bottom: 40rpx;
}
.desc {
  font-size: 28rpx;
  color: var(--ck-subtle);
  text-align: center;
  margin-bottom: 60rpx;
}
.scan-btn {
  width: 480rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--ck-primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.manual-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}
.manual-toggle {
  font-size: 26rpx;
  color: var(--ck-primary);
  padding: 16rpx;
}
.manual-input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 620rpx;
}
.code-input {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid var(--ck-border);
  border-radius: var(--ck-radius-md);
  padding: 0 24rpx;
  font-size: 38rpx;
  text-align: center;
  letter-spacing: 8rpx;
  text-transform: uppercase;
}
.confirm-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--ck-primary);
  color: #fff;
  border-radius: var(--ck-radius-md);
  font-size: 28rpx;
  text-align: center;
}
.hint {
  padding: 24rpx;
  background: var(--ck-bg);
  border-radius: var(--ck-radius-md);
}
.hint text {
  font-size: 24rpx;
  color: var(--ck-subtle);
}
