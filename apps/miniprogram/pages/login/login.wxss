.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 0;
}
.brand-lockup {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 12rpx;
}
.logo-mark {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  border-radius: 34rpx;
  background: #161412;
  box-shadow: 0 22rpx 58rpx rgba(28, 25, 23, 0.22);
}
.logo-mark::before {
  content: '';
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 16rpx;
  bottom: 16rpx;
  border-radius: 26rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
}
.mark-phone {
  position: absolute;
  left: 47rpx;
  top: 27rpx;
  width: 58rpx;
  height: 96rpx;
  border: 5rpx solid #f7f3ee;
  border-radius: 18rpx;
}
.mark-phone::before {
  content: '';
  position: absolute;
  left: 19rpx;
  top: 10rpx;
  width: 18rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #f7f3ee;
}
.mark-code {
  position: absolute;
  top: 66rpx;
  width: 19rpx;
  height: 19rpx;
  border-color: #7dd3fc;
  border-style: solid;
  transform: rotate(45deg);
}
.mark-code.left {
  left: 22rpx;
  border-width: 0 0 6rpx 6rpx;
}
.mark-code.right {
  right: 22rpx;
  border-width: 6rpx 6rpx 0 0;
}
.mark-check {
  position: absolute;
  left: 15rpx;
  top: 43rpx;
  width: 32rpx;
  height: 18rpx;
  border-left: 7rpx solid #86efac;
  border-bottom: 7rpx solid #86efac;
  border-radius: 3rpx;
  transform: rotate(-45deg);
}
.mark-signal {
  position: absolute;
  right: 14rpx;
  top: 12rpx;
  width: 38rpx;
  height: 38rpx;
  transform: rotate(45deg);
}
.signal-arc {
  position: absolute;
  left: 50%;
  border-top: 6rpx solid #f59e0b;
  border-radius: 999rpx 999rpx 0 0;
  transform: translateX(-50%);
}
.signal-arc.outer {
  top: 7rpx;
  width: 32rpx;
  height: 20rpx;
}
.signal-arc.inner {
  top: 18rpx;
  width: 18rpx;
  height: 11rpx;
}
.signal-dot {
  position: absolute;
  left: 15rpx;
  bottom: 3rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #f59e0b;
  box-shadow: 0 6rpx 16rpx rgba(245, 158, 11, 0.35);
}
.logo {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--ck-text);
  letter-spacing: 0;
}
.subtitle {
  font-size: 32rpx;
  color: var(--ck-muted);
  margin-bottom: 40rpx;
}
.desc {
  font-size: 28rpx;
  color: var(--ck-subtle);
  text-align: center;
  margin-bottom: 60rpx;
}
.scan-btn {
  width: 480rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--ck-primary);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.manual-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}
.manual-toggle {
  font-size: 26rpx;
  color: var(--ck-primary);
  padding: 16rpx;
}
.manual-input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 620rpx;
}
.code-input {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid var(--ck-border);
  border-radius: var(--ck-radius-md);
  padding: 0 24rpx;
  font-size: 38rpx;
  text-align: center;
  letter-spacing: 8rpx;
  text-transform: uppercase;
}
.confirm-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--ck-primary);
  color: #fff;
  border-radius: var(--ck-radius-md);
  font-size: 28rpx;
  text-align: center;
}
.hint {
  padding: 32rpx 28rpx;
  background: var(--ck-bg);
  border-radius: var(--ck-radius-md);
  line-height: 1.6;
}
.hint text {
  font-size: 26rpx;
  color: var(--ck-subtle);
}
.loading-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: var(--ck-bg, #0f0f18);
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--ck-border, #333);
  border-top-color: var(--ck-primary, #5c9cf5);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--ck-subtle, #888);
}
