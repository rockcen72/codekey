.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 0;
}
.logo {
  font-size: 72rpx;
  font-weight: 800;
  color: #07c160;
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}
.desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 60rpx;
}
.scan-btn {
  width: 480rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.manual-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}
.manual-toggle {
  font-size: 26rpx;
  color: #07c160;
  padding: 16rpx;
}
.manual-input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 520rpx;
}
.code-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  text-align: center;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}
.confirm-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}
.hint {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.hint text {
  font-size: 24rpx;
  color: #999;
}
