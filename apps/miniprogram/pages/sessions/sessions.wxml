<view class="page">
  <view class="topbar">
    <view class="topbar-left">
      <text class="brand">History</text>
      <text class="brand-sub">CodeKey AI 远程控制</text>
    </view>
    <view class="top-actions">
      <view class="conn-pill {{wsConnected ? 'online' : 'offline'}}">
        <view class="conn-dot"></view>
        <text>{{wsConnected ? '已连接' : '离线'}}</text>
      </view>
      <view class="icon-btn-wrap" bindtap="goToSettings">
        <text class="icon-btn">⚙</text>
      </view>
    </view>
  </view>

  <!-- Metrics: compact row -->
  <view class="metrics-row" wx:if="{{sessions.length > 0 || pendingTotal > 0}}">
    <view class="metric-chip" wx:if="{{activeTotal > 0}}">
      <view class="metric-dot active"></view>
      <text>{{activeTotal}} 活跃</text>
    </view>
    <view class="metric-chip danger" wx:if="{{pendingTotal > 0}}">
      <view class="metric-dot pending"></view>
      <text>{{pendingTotal}} 待审批</text>
    </view>
  </view>

  <scroll-view class="list" scroll-y>
    <view class="empty" wx:if="{{sessions.length === 0}}">
      <text class="empty-icon">◌</text>
      <text class="empty-title">暂无对话记录</text>
      <text class="empty-text">在 VS Code 中启动 Claude Code 后，关联的会话将出现在这里。</text>
    </view>

    <view class="swipe-wrap" wx:for="{{sessions}}" wx:key="id"
          data-id="{{item.id}}"
          bindtouchstart="onTouchStart"
          bindtouchend="onTouchEnd">
      <!-- Swipe-inner: card + delete button side by side -->
      <view class="swipe-inner {{item.swiped ? 'swiped' : ''}}">
        <!-- Main card -->
        <view class="session-card {{item.hasPending ? 'has-pending' : ''}} {{item.connected ? 'connected' : ''}}"
              data-id="{{item.id}}"
              bindtap="openSession">
          <!-- Connection status bar: orange (connected) / gray (offline) -->
          <view class="conn-bar {{item.connected ? 'online' : 'offline'}}"></view>

          <view class="card-body">
            <view class="card-top">
              <view class="card-title-row">
                <text class="session-title ellipsis">{{item.displayTitle}}</text>
              </view>
              <view class="card-time-wrap">
                <text class="session-time">{{item.displayTime}}</text>
              </view>
            </view>

            <text class="session-subtitle ellipsis">{{item.displaySubtitle}}</text>

            <view class="card-footer">
              <text class="session-id mono" wx:if="{{item.displayClaudeId}}">{{item.displayClaudeId}}</text>
            </view>
          </view>
        </view>

        <!-- Delete button revealed on swipe -->
        <view class="delete-area" data-id="{{item.id}}" catchtap="deleteSession">
          <text class="delete-text">删除</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
