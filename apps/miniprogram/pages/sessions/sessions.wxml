<view class="container">
  <view class="header">
    <text class="title">会话列表</text>
    <view class="ws-indicator {{wsConnected ? 'connected' : ''}}"></view>
    <text class="settings-link" bindtap="goToSettings">设置</text>
  </view>

  <scroll-view class="list" scroll-y>
    <view class="empty" wx:if="{{sessions.length === 0}}">
      <text>暂无活跃会话</text>
      <text class="empty-hint">当 AI 代理正在运行时，会话将显示在这里</text>
    </view>

    <view class="session-card" wx:for="{{sessions}}" wx:key="id"
          data-id="{{item.id}}" bindtap="openSession">
      <view class="card-header">
        <text class="agent">{{item.agent_type}}</text>
        <text class="status {{item.status}}">{{item.status}}</text>
      </view>
      <view class="card-body">
        <text class="project">{{item.projectName}}</text>
      </view>
      <view class="card-footer">
        <text class="time">{{item.displayTime}}</text>
      </view>
    </view>
  </scroll-view>
</view>
