<view class="page">
  <view class="topbar">
    <view class="topbar-left">
      <text class="brand">History</text>
      <text class="brand-sub">CodeKey AI 远程控制</text>
    </view>
    <view class="top-actions">
      <!-- Subscription pill (P4.1). Hidden when not authenticated
           or when the server call failed — those users can still
           reach settings via the gear icon. -->
      <view
        wx:if="{{subTier !== 'unauthenticated' && subTier !== 'load_failed'}}"
        class="sub-pill {{subPillClass}}"
        bindtap="goToSettingsFromPill"
      >
        <text>{{subPillText}}</text>
      </view>
      <view class="conn-pill {{wsConnected ? 'online' : 'offline'}}">
        <view class="conn-dot"></view>
        <text>{{wsConnected ? '已连接' : '离线'}}</text>
      </view>
      <view class="icon-btn-wrap" bindtap="goToSettings">
        <text class="icon-btn">⚙</text>
      </view>
    </view>
  </view>

  <!-- Metrics: compact row -->
  <view class="metrics-row" wx:if="{{activeTotal > 0}}">
    <view class="metric-chip">
      <view class="metric-dot active"></view>
      <text>{{activeTotal}} 活跃</text>
    </view>
  </view>

  <!-- Agent tabs: all / per-agent -->
  <scroll-view class="tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tabs">
      <view wx:for="{{agentTabs}}" wx:key="key"
            class="tab {{activeTab === item.key ? 'active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onTabTap">
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <scroll-view class="list" scroll-y>
    <!-- Empty state -->
    <view class="empty" wx:if="{{filteredSessions.length === 0}}">
      <text class="empty-icon">◌</text>
      <text class="empty-title">暂无对话记录</text>
      <text class="empty-text">在 VS Code 中启动 AI 代理后，关联的会话将出现在这里。</text>
    </view>

    <!-- Session items -->
    <view class="swipe-wrap" wx:for="{{filteredSessions}}" wx:key="id"
          data-id="{{item.id}}"
          bindtouchstart="onTouchStart"
          bindtouchend="onTouchEnd">
      <view class="swipe-inner {{item.swiped ? 'swiped' : ''}}">
        <view class="session-card {{item.hasPending ? 'has-pending' : ''}} {{item.connected ? 'connected' : ''}}"
              data-id="{{item.id}}"
              bindtap="openSession">
          <view class="conn-bar {{item.connected ? 'online' : 'offline'}} agent-{{item.agentClass}}"></view>
          <view class="card-body">
            <view class="card-top">
              <view class="card-title-row">
                <text class="session-title ellipsis">{{item.displayTitle}}</text>
                <text class="agent-chip">{{item.displayAgentLabel}}</text>
              </view>
              <view class="card-time-wrap">
                <text class="session-time">{{item.displayTime}}</text>
              </view>
            </view>
            <text class="session-subtitle ellipsis">{{item.displaySubtitle}}</text>
            <view class="card-footer">
              <text class="session-id mono" wx:if="{{item.displayClaudeId}}">{{item.displayClaudeId}}</text>
              <view wx:if="{{item.hasPending}}" class="pending-badge">
                <text class="pending-badge-num">{{item.pendingCount}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="delete-area" data-id="{{item.id}}" catchtap="deleteSession">
          <text class="delete-text">删除</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
