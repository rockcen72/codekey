<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">◀</text>
    </view>
    <view class="header-info">
      <text class="header-title">{{session.agentType || 'AI Agent'}}</text>
      <text class="header-status {{session.status}}">{{session.status === 'active' ? '在线' : '离线'}}</text>
    </view>
    <view class="ws-dot {{wsConnected ? 'on' : 'off'}}"></view>
  </view>

  <!-- Chat messages -->
  <scroll-view class="chat-list" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation upper-threshold="100">
    <view class="empty" wx:if="{{chatMessages.length === 0}}">
      <text>暂无消息</text>
    </view>

    <block wx:for="{{chatMessages}}" wx:key="id">
      <!-- System messages (centered) -->
      <view wx:if="{{item.type === 'system'}}" class="system-wrap">
        <view class="system-bubble">
          <text class="system-text">{{item.content}}</text>
        </view>
      </view>

      <!-- User messages (right side) -->
      <view wx:elif="{{item.side === 'right'}}" class="msg-row right" id="msg-{{item.id}}">
        <view class="msg-bubble right-bubble">
          <text class="msg-text">{{item.content}}</text>
          <text class="msg-time right-time">{{item.displayTime}}</text>
        </view>
        <view class="avatar user-avatar">
          <text>我</text>
        </view>
      </view>

      <!-- AI messages (left side) -->
      <view wx:else class="msg-row left" id="msg-{{item.id}}">
        <view class="avatar ai-avatar">
          <text>AI</text>
        </view>
        <view class="msg-bubble left-bubble {{item.isTaskComplete ? 'complete-bubble' : ''}}">
          <!-- Header row -->
          <view class="bubble-header">
            <text class="bubble-type {{item.isTaskComplete ? 'complete-label' : ''}}">{{item.typeLabel}}</text>
          </view>

          <!-- Command (approval_required) -->
          <view wx:if="{{item.command}}" class="code-block">
            <text class="code-text">{{item.command}}</text>
          </view>

          <!-- Task summary (task_complete) -->
          <view wx:if="{{item.summary}}" class="summary-block">
            <text class="summary-text {{item.isTaskComplete ? 'complete-summary' : ''}}">{{item.summary}}</text>
          </view>

          <!-- Risk tag (pending approval) -->
          <view wx:if="{{item.riskText && item.pending}}" class="tag-row">
            <text class="risk-tag {{item.risk_level}}">{{item.riskText}}</text>
          </view>

          <!-- Decision badge (responded) -->
          <view wx:elif="{{item.decisionText}}" class="tag-row">
            <text class="decision-tag {{item.decision}}">{{item.decisionText}}</text>
          </view>

          <!-- Time -->
          <text class="bubble-time">{{item.displayTime}}</text>

          <!-- Action buttons (pending approval) -->
          <view wx:if="{{item.pending && item.canApprove}}" class="action-row">
            <button class="chat-action-btn approve" data-id="{{item.id}}" bindtap="approveEvent">批准</button>
            <button class="chat-action-btn deny" data-id="{{item.id}}" bindtap="denyEvent">拒绝</button>
            <button class="chat-action-btn pause" data-id="{{item.id}}" bindtap="pauseEvent">暂缓</button>
          </view>

          <!-- High risk notice -->
          <view wx:elif="{{item.pending && !item.canApprove}}" class="risk-notice-inline">
            <text>风险较高，请在电脑端处理</text>
          </view>

          <!-- Inline reply (pending approval) -->
          <view wx:if="{{item.pending}}" class="reply-inline">
            <input class="inline-reply-input" placeholder="回复 AI..." data-id="{{item.id}}" bindinput="onReplyInput" />
            <button class="inline-reply-btn" data-id="{{item.id}}" bindtap="sendReply">发送</button>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- Bottom input bar -->
  <view class="input-bar">
    <input class="chat-input" placeholder="输入指令..." value="{{commandText}}" bindinput="onCommandInput" />
    <button class="send-btn" bindtap="sendCommand">发送</button>
  </view>
</view>
