<view class="container">
  <view class="header">
    <text class="back" bindtap="goBack">返回</text>
    <text class="title">会话详情</text>
  </view>

  <view class="info-card" wx:if="{{session}}">
    <text class="agent">{{session.agent_type}}</text>
    <text class="status {{session.status}}">{{session.status}}</text>
  </view>

  <scroll-view class="event-list" scroll-y>
    <view class="empty" wx:if="{{events.length === 0}}">
      <text>暂无事件</text>
    </view>

    <view class="event-item {{item.isTaskComplete ? 'task-complete' : ''}}"
          wx:for="{{events}}" wx:key="id"
          data-id="{{item.id}}"
          bindtap="{{item.isTaskComplete ? '' : 'showApprovalCard'}}">
      <view class="event-time">{{item.displayTime}}</view>
      <view class="event-body">
        <view class="event-type-row">
          <text wx:if="{{item.isTaskComplete}}" class="icon-check">✓</text>
          <text class="event-type">{{item.isTaskComplete ? '任务完成' : item.type}}</text>
        </view>
        <text class="event-summary">{{item.isTaskComplete ? (item.summaryShort || item.summary) : item.summary}}</text>
        <view class="event-meta">
          <text wx:if="{{!item.isTaskComplete}}" class="risk-badge {{item.risk_level || 'unknown'}}">{{item.riskText}}</text>
          <text wx:if="{{item.showPending}}" class="pending-badge">待处理</text>
          <text wx:elif="{{item.showDecision}}" class="decision-badge">{{item.decision}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Remote Command Input -->
  <view class="command-bar" wx:if="{{session && session.status === 'active'}}">
    <input class="command-input" placeholder="输入指令发送给 AI Agent..." value="{{commandText}}" bindinput="onCommandInput" />
    <button class="command-send-btn" bindtap="sendCommand">发送</button>
  </view>

  <!-- Approval Card Modal -->
  <view class="modal-overlay" wx:if="{{showApproval}}" bindtap="closeApprovalCard">
    <view class="approval-card" catchtap="">
      <view class="card-header">
        <text class="card-title">审批请求</text>
        <text class="card-close" bindtap="closeApprovalCard">X</text>
      </view>

      <view wx:if="{{currentEvent}}" class="card-body">
        <!-- Risk badge + agent -->
        <view class="approval-meta">
          <text class="risk-tag {{riskLevel}}">{{riskLabel}}</text>
          <text class="agent-tag">{{session.agentType}}</text>
        </view>

        <!-- Summary (main description) -->
        <view class="summary-block" wx:if="{{approvalSummary}}">
          <text class="summary-text">{{approvalSummary}}</text>
        </view>

        <!-- Command (terminal-style block) -->
        <view class="command-block" wx:if="{{approvalCommand}}">
          <text class="block-label">即将执行的命令</text>
          <view class="command-box">
            <text class="command-text">{{approvalCommand}}</text>
          </view>
        </view>

        <!-- Directory -->
        <view class="detail-row" wx:if="{{approvalCwd}}">
          <text class="detail-label">工作目录</text>
          <text class="detail-value code">{{approvalCwd}}</text>
        </view>
      </view>

      <view class="card-actions">
        <button class="action-btn approve {{approvalDisabled ? 'disabled' : ''}}"
                disabled="{{approvalDisabled}}" bindtap="approve">批准</button>
        <button class="action-btn deny" bindtap="deny">拒绝</button>
        <button class="action-btn pause" bindtap="pause">暂停</button>
      </view>

      <view class="reply-section">
        <input class="reply-input" placeholder="输入回复..." value="{{replyText}}" bindinput="onReplyInput" />
        <button class="reply-btn" bindtap="sendReply">发送</button>
      </view>

      <view wx:if="{{showRiskNotice}}" class="risk-notice">
        <text>风险等级 {{riskLabel}} 无法在手机上批准，请到电脑端处理。</text>
      </view>
    </view>
  </view>
</view>
