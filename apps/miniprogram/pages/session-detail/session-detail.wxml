<view class="page">
  <view class="detail-topbar">
    <button class="back-btn" bindtap="goBack"></button>
    <view class="title-wrap">
      <text class="detail-title ellipsis">{{session.metadataTitle || session.agentType || 'AI Agent'}}</text>
    </view>
    <view class="ws-indicator {{wsConnected ? 'online' : 'offline'}}">
      <view class="ws-dot"></view>
    </view>
  </view>

  <!-- Per-user monthly quota bar. Hidden when not on the free
       tier (paid/trial return usage=null and the bar stays
       hidden). Color shifts to warn the user as they approach
       the 50/month cap. -->
  <view class="quota-strip" wx:if="{{quotaState !== 'hidden'}}">
    <view class="quota-strip-bar">
      <view class="quota-strip-fill quota-{{quotaState}}" style="width: {{quotaPercent}}%"></view>
    </view>
    <text class="quota-strip-label quota-label-{{quotaState}}">
      <text wx:if="{{quotaState === 'exhausted'}}">本月 {{usage.limit}} 次审批已用完</text>
      <text wx:elif="{{quotaState === 'approaching'}}">本月 {{usage.used}}/{{usage.limit}} · 接近额度上限</text>
      <text wx:else>本月 {{usage.used}}/{{usage.limit}}</text>
    </text>
  </view>

  <scroll-view class="timeline" scroll-y scroll-into-view="{{scrollToId}}" scroll-top="{{scrollTop}}" scroll-with-animation bindscroll="onScroll">
    <view class="empty" wx:if="{{chatMessages.length === 0}}">
      <text class="empty-icon">◌</text>
      <text class="empty-title">暂无消息</text>
      <text class="empty-text">当 Agent 请求审批、完成任务或等待指令时，会显示在这里。</text>
    </view>

    <block wx:for="{{chatMessages}}" wx:key="id">
      <!-- System markers (e.g. session idle) -->
      <view wx:if="{{item.type === 'system'}}" class="marker-wrap" id="msg-{{item.id}}">
        <view class="timeline-marker">
          <text>{{item.content}}</text>
        </view>
      </view>

      <!-- User message bubble -->
      <view wx:elif="{{item.type === 'user'}}" class="msg-row right">
        <view class="chat-stack user-stack" id="msg-{{item.id}}">
          <text class="sender-name">{{item.senderName || '你'}}</text>
          <view class="msg-bubble user">
            <text class="msg-text">{{item.content}}</text>
            <text wx:if="{{item.displayTime}}" class="msg-time">{{item.displayTime}}</text>
          </view>
        </view>
      </view>

      <!-- Agent event card -->
      <view wx:else class="msg-row left">
        <view class="chat-stack agent-stack" id="msg-{{item.id}}">
          <text class="sender-name">{{item.senderName || 'agent'}}</text>
          <view class="event-card accent-{{item.accent}} agent-{{item.agentClass}}">
            <view class="event-head">
              <view class="event-head-left">
                <view class="event-glyph glyph-{{item.accent}}"></view>
                <text class="event-type">{{item.typeLabel}}</text>
                <text wx:if="{{item.toolName}}" class="tool-tag">{{item.toolName}}</text>
              </view>
              <text wx:if="{{item.kindBadge}}" class="kind-badge kind-{{item.accent}}">{{item.kindBadge}}</text>
            </view>

            <!-- Command single-line preview -->
            <view wx:if="{{item.command}}" class="cmd-line">
              <text class="cmd-line-text mono">{{item.command}}</text>
            </view>
            <!-- Summary if different from command -->
            <view wx:if="{{item.summary && item.summary !== item.command}}" class="event-summary">{{item.summary}}</view>
            <view wx:if="{{item.requiresInput && item.inputOptions && item.inputOptions.length}}" class="input-options">
              <button
                wx:for="{{item.inputOptions}}"
                wx:key="value"
                class="input-option"
                data-id="{{item.eventId}}"
                data-value="{{item.value}}"
                disabled="{{!item.pending}}"
                catchtap="chooseInputOption"
              >
                <text class="input-option-label">{{item.label}}</text>
                <text wx:if="{{item.description}}" class="input-option-desc">{{item.description}}</text>
              </button>
            </view>

            <!-- Footer: status tags + time -->
            <view class="event-foot">
              <view class="foot-tags">
                <!-- Pending: risk + wait pulse -->
                <block wx:if="{{item.pending && item.riskText}}">
                  <text class="risk-tag {{item.risk_level}}">{{item.riskText}}</text>
                  <view class="pending-pulse">
                    <view class="pulse-dot"></view>
                    <text>等待处理</text>
                  </view>
                </block>
                <!-- Resolved: decision -->
                <text wx:elif="{{item.decisionText}}" class="decision-tag {{item.decision}}">{{item.decisionText}}</text>
              </view>
              <text wx:if="{{item.displayTime}}" class="event-time">{{item.displayTime}}</text>
            </view>

            <!-- Action buttons for pending -->
            <view wx:if="{{item.pending && item.requiresInput}}" class="action-bar">
              <button class="action-btn outline" data-id="{{item.eventId}}" bindtap="openApprovalSheet">回复</button>
            </view>
            <view wx:elif="{{item.pending && item.canApprove}}" class="action-bar">
              <button class="action-btn primary" data-id="{{item.eventId}}" catchtap="approveEvent">批准</button>
              <button class="action-btn secondary" data-id="{{item.eventId}}" catchtap="denyEvent">拒绝</button>
              <button class="action-btn ghost" data-id="{{item.eventId}}" catchtap="pauseEvent">暂缓</button>
              <button class="action-btn outline" data-id="{{item.eventId}}" bindtap="openApprovalSheet">回复</button>
            </view>
            <view wx:elif="{{item.pending}}" class="action-bar">
              <button class="action-btn outline" data-id="{{item.eventId}}" bindtap="openApprovalSheet">查看详情</button>
              <button class="action-btn ghost" data-id="{{item.eventId}}" catchtap="denyEvent">拒绝</button>
              <button class="action-btn ghost" data-id="{{item.eventId}}" catchtap="pauseEvent">暂缓</button>
            </view>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- Floating approval focus card -->
  <view class="approval-focus" wx:if="{{hasPrimaryPendingEvent && !approvalSheetOpen}}">
    <view class="focus-card accent-{{primaryPendingEvent.accent}} agent-{{primaryPendingEvent.agentClass}}">
      <view class="focus-top">
        <view class="focus-title-wrap">
          <text class="focus-kicker">{{primaryPendingEvent.requiresInput ? '需要选择' : '等待审批'}}</text>
          <text class="focus-title">{{primaryPendingEvent.summary || primaryPendingEvent.command || primaryPendingEvent.typeLabel}}</text>
        </view>
        <text wx:if="{{primaryPendingEvent.riskText}}" class="risk-tag {{primaryPendingEvent.risk_level}}">{{primaryPendingEvent.riskText}}</text>
      </view>

      <view wx:if="{{primaryPendingEvent.command}}" class="focus-command">
        <text class="focus-command-text mono">{{primaryPendingEvent.command}}</text>
      </view>

      <view wx:if="{{primaryPendingEvent.requiresInput}}" class="focus-actions single">
        <button class="focus-btn primary" data-id="{{primaryPendingEvent.eventId}}" bindtap="openApprovalSheet">选择 / 回复</button>
      </view>
      <view wx:elif="{{primaryPendingEvent.canApprove}}" class="focus-actions">
        <button class="focus-btn primary" data-id="{{primaryPendingEvent.eventId}}" catchtap="approveEvent">批准</button>
        <button class="focus-btn danger" data-id="{{primaryPendingEvent.eventId}}" catchtap="denyEvent">拒绝</button>
        <button class="focus-icon-btn" data-id="{{primaryPendingEvent.eventId}}" catchtap="pauseEvent">暂缓</button>
        <button class="focus-icon-btn" data-id="{{primaryPendingEvent.eventId}}" bindtap="openApprovalSheet">详情</button>
      </view>
      <view wx:else class="focus-actions">
        <button class="focus-btn primary" data-id="{{primaryPendingEvent.eventId}}" bindtap="openApprovalSheet">查看详情</button>
        <button class="focus-icon-btn" data-id="{{primaryPendingEvent.eventId}}" catchtap="denyEvent">拒绝</button>
        <button class="focus-icon-btn" data-id="{{primaryPendingEvent.eventId}}" catchtap="pauseEvent">暂缓</button>
      </view>
    </view>
  </view>

  <!-- Composer: input + circular send button -->
  <view class="composer">
    <view class="composer-inner">
      <view class="composer-media-btn" aria-label="添加图片">
        <view class="media-icon">
          <view class="media-sun"></view>
          <view class="media-mountain"></view>
        </view>
      </view>
      <view class="composer-input-wrap">
        <input class="composer-input" placeholder="给 Agent 发送指令..." value="{{commandText}}" bindinput="onCommandInput" />
      </view>
      <view class="composer-send {{canSendCommand ? 'active' : ''}}" bindtap="sendCommand">
        <view class="send-arrow">
          <view class="send-arrow-head"></view>
          <view class="send-arrow-shaft"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- Approval detail modal -->
  <view class="sheet-mask" wx:if="{{approvalSheetOpen}}" bindtap="closeApprovalSheet">
    <view class="approval-sheet" catchtap="">
      <view class="sheet-head">
        <view class="event-head-left">
          <text class="sheet-title">{{approvalEvent.requiresInput ? '选择请求' : '审批请求'}}</text>
          <text wx:if="{{approvalEvent.toolName}}" class="tool-tag">{{approvalEvent.toolName}}</text>
        </view>
        <text wx:if="{{!approvalEvent.requiresInput}}" class="risk-tag {{approvalEvent.risk_level}}">{{approvalEvent.riskText}}</text>
      </view>

      <text class="sheet-summary" wx:if="{{approvalEvent.summary}}">{{approvalEvent.summary}}</text>

      <view class="code-block large" wx:if="{{approvalEvent.command && approvalEvent.toolName === 'Bash' && approvalEvent.command !== approvalEvent.summary}}">
        <text class="code-text">{{approvalEvent.command}}</text>
      </view>

      <view class="risk-notice" wx:if="{{approvalEvent.pending && !approvalEvent.requiresInput && !approvalEvent.canApprove}}">
        <text>该请求风险较高，请在电脑端确认后处理。</text>
      </view>

      <view wx:if="{{approvalEvent.requiresInput && approvalEvent.inputOptions && approvalEvent.inputOptions.length}}" class="input-options sheet-options">
        <button
          wx:for="{{approvalEvent.inputOptions}}"
          wx:key="value"
          class="input-option"
          data-id="{{approvalEvent.eventId}}"
          data-value="{{item.value}}"
          catchtap="chooseSheetInputOption"
        >
          <text class="input-option-label">{{item.label}}</text>
          <text wx:if="{{item.description}}" class="input-option-desc">{{item.description}}</text>
        </button>
      </view>

      <view class="sheet-reply">
        <input class="sheet-reply-input" placeholder="{{approvalEvent.requiresInput ? '输入选择或补充说明...' : '回复 AI...'}}" value="{{sheetReplyText}}" bindinput="onSheetReplyInput" />
        <button class="sheet-reply-btn" bindtap="sendSheetReply">发送</button>
      </view>

      <view wx:if="{{!approvalEvent.requiresInput}}" class="sheet-actions">
        <button class="sheet-btn approve {{approvalEvent.canApprove ? '' : 'disabled'}}" disabled="{{!approvalEvent.canApprove}}" bindtap="approveSheet">批准</button>
        <button class="sheet-btn deny" bindtap="denySheet">拒绝</button>
        <button class="sheet-btn pause" bindtap="pauseSheet">暂缓</button>
      </view>
    </view>
  </view>
</view>
