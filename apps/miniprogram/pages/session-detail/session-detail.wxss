.container { display: flex; flex-direction: column; height: 100vh; }
.header { display: flex; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid #eee; }
.back { font-size: 28rpx; color: #07c160; margin-right: 16rpx; }
.title { font-size: 36rpx; font-weight: 700; flex: 1; }
.info-card { padding: 24rpx 32rpx; background: #fff; border-bottom: 1rpx solid #f0f0f0; }
.agent { font-size: 32rpx; font-weight: 600; }
.status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx; margin-left: 16rpx; }
.status.active { background: #e8f5e9; color: #2e7d32; }
.event-list { flex: 1; padding: 16rpx 24rpx; }
.empty { text-align: center; padding-top: 200rpx; color: #999; font-size: 32rpx; }
.event-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.event-time { font-size: 22rpx; color: #ccc; width: 100rpx; }
.event-body { flex: 1; }
.event-type { font-size: 28rpx; font-weight: 600; display: block; }
.event-summary { font-size: 26rpx; color: #666; display: block; margin-top: 4rpx; }
.event-meta { margin-top: 8rpx; display: flex; align-items: center; }
.risk-badge { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }
.risk-badge.low { background: #e8f5e9; color: #2e7d32; }
.risk-badge.medium { background: #fff3e0; color: #e65100; }
.risk-badge.high { background: #fbe9e7; color: #c62828; }
.risk-badge.critical { background: #fce4ec; color: #880e4f; }
.risk-badge.unknown { background: #f5f5f5; color: #666; }
.pending-badge { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; background: #fff8e1; color: #f57f17; margin-left: 8rpx; }
.decision-badge { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; background: #e8f5e9; color: #2e7d32; margin-left: 8rpx; }

/* Task Complete Card */
.event-item.task-complete { background: #f0faf0; border-radius: 12rpx; padding: 16rpx; margin-bottom: 8rpx; border-bottom: none; }
.event-type-row { display: flex; align-items: center; gap: 8rpx; }
.icon-check { font-size: 28rpx; color: #07c160; font-weight: 700; }

/* Approval Card Modal */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: flex-end; z-index: 100; }
.approval-card { width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; max-height: 80vh; overflow-y: auto; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.card-title { font-size: 34rpx; font-weight: 700; }
.card-close { font-size: 32rpx; color: #999; padding: 8rpx; }
.card-body { margin-bottom: 24rpx; }
.approval-meta { display: flex; align-items: center; gap: 12rpx; margin-bottom: 24rpx; }
.agent-tag { font-size: 22rpx; color: #666; background: #f0f0f0; padding: 4rpx 12rpx; border-radius: 8rpx; }
.summary-block { margin-bottom: 24rpx; }
.summary-text { font-size: 30rpx; font-weight: 600; color: #222; line-height: 1.5; }
.command-block { margin-bottom: 20rpx; }
.block-label { font-size: 22rpx; color: #999; display: block; margin-bottom: 8rpx; }
.command-box { background: #1e1e1e; border-radius: 12rpx; padding: 20rpx; }
.command-text { font-family: 'Courier New', monospace; font-size: 24rpx; color: #d4d4d4; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
.risk-row { margin-bottom: 16rpx; }
.risk-tag { font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 8rpx; }
.risk-tag.low { background: #e8f5e9; color: #2e7d32; }
.risk-tag.medium { background: #fff3e0; color: #e65100; }
.risk-tag.high { background: #fbe9e7; color: #c62828; }
.risk-tag.critical { background: #fce4ec; color: #880e4f; }
.risk-tag.unknown { background: #f5f5f5; color: #666; }
.detail-row { margin-bottom: 12rpx; }
.detail-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 4rpx; }
.detail-value { font-size: 28rpx; color: #333; display: block; }
.detail-value.code { font-family: monospace; background: #f5f5f5; padding: 12rpx; border-radius: 8rpx; font-size: 24rpx; }
.card-actions { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.action-btn { flex: 1; height: 72rpx; line-height: 72rpx; text-align: center; border-radius: 12rpx; font-size: 28rpx; color: #fff; }
.action-btn.approve { background: #07c160; }
.action-btn.approve.disabled { background: #ccc; }
.action-btn.deny { background: #e64340; }
.action-btn.pause { background: #ff9800; }
.reply-section { display: flex; gap: 12rpx; align-items: center; margin-bottom: 16rpx; }
.reply-input { flex: 1; height: 64rpx; border: 1rpx solid #ddd; border-radius: 12rpx; padding: 0 16rpx; font-size: 26rpx; }
.reply-btn { height: 64rpx; line-height: 64rpx; background: #07c160; color: #fff; border-radius: 12rpx; font-size: 26rpx; padding: 0 24rpx; }
.risk-notice { background: #fff3e0; padding: 16rpx; border-radius: 12rpx; font-size: 24rpx; color: #e65100; text-align: center; }

/* Remote Command Input Bar */
.command-bar { display: flex; gap: 12rpx; align-items: center; padding: 16rpx 24rpx; border-top: 1rpx solid #eee; background: #fff; }
.command-input { flex: 1; height: 64rpx; border: 1rpx solid #ddd; border-radius: 12rpx; padding: 0 16rpx; font-size: 26rpx; }
.command-send-btn { height: 64rpx; line-height: 64rpx; background: #07c160; color: #fff; border-radius: 12rpx; font-size: 26rpx; padding: 0 32rpx; white-space: nowrap; }
