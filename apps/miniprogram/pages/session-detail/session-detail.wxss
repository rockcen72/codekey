/* ── Container ── */
.container { display: flex; flex-direction: column; height: 100vh; background: #ededed; }

/* ── Header ── */
.header { display: flex; align-items: center; padding: 12rpx 24rpx; background: #fff; border-bottom: 1rpx solid #e0e0e0; }
.back-btn { padding: 8rpx 16rpx 8rpx 0; }
.back-arrow { font-size: 32rpx; color: #07c160; }
.header-info { flex: 1; display: flex; flex-direction: column; }
.header-title { font-size: 34rpx; font-weight: 600; }
.header-status { font-size: 22rpx; color: #999; }
.header-status.active { color: #07c160; }
.ws-dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-left: 12rpx; }
.ws-dot.on { background: #07c160; }
.ws-dot.off { background: #ccc; }

/* ── Chat scroll area ── */
.chat-list { flex: 1; padding: 20rpx 24rpx 30rpx; overflow-y: scroll; -webkit-overflow-scrolling: touch; }
.empty { text-align: center; padding-top: 300rpx; color: #999; font-size: 30rpx; }

/* ── System messages ── */
.system-wrap { text-align: center; margin: 16rpx 0; }
.system-bubble { display: inline-block; background: rgba(0,0,0,0.05); border-radius: 8rpx; padding: 6rpx 20rpx; }
.system-text { font-size: 22rpx; color: #999; }

/* ── Message row ── */
.msg-row { display: flex; align-items: flex-start; margin-bottom: 24rpx; }
.msg-row.right { flex-direction: row-reverse; }

/* ── Avatar ── */
.avatar { width: 72rpx; height: 72rpx; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 600; flex-shrink: 0; }
.ai-avatar { background: #07c160; color: #fff; margin-right: 16rpx; }
.user-avatar { background: #95ec69; color: #fff; margin-left: 16rpx; }

/* ── Message bubble ── */
.msg-bubble { max-width: 75%; padding: 16rpx 20rpx; border-radius: 12rpx; font-size: 28rpx; line-height: 1.5; word-break: break-word; }
.left-bubble { background: #fff; border-top-left-radius: 4rpx; }
.right-bubble { background: #95ec69; border-top-right-radius: 4rpx; }
.complete-bubble { background: #f0faf0; }

/* ── Bubble contents ── */
.bubble-header { margin-bottom: 8rpx; }
.bubble-type { font-size: 22rpx; color: #999; font-weight: 500; }
.bubble-type.complete-label { color: #07c160; }
.msg-text { font-size: 30rpx; display: block; }
.msg-time { font-size: 20rpx; color: rgba(0,0,0,0.3); display: block; margin-top: 4rpx; }
.right-time { text-align: right; color: rgba(0,0,0,0.35); }

/* ── Code block ── */
.code-block { background: #1e1e1e; border-radius: 10rpx; padding: 16rpx 18rpx; margin: 8rpx 0; }
.code-text { font-family: 'Courier New', monospace; font-size: 22rpx; color: #d4d4d4; line-height: 1.6; word-break: break-all; white-space: pre-wrap; }

/* ── Summary ── */
.summary-block { margin: 8rpx 0; }
.summary-text { font-size: 28rpx; color: #333; line-height: 1.5; }
.complete-summary { color: #1b5e20; }

/* ── Tags ── */
.tag-row { margin: 8rpx 0; }
.risk-tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 6rpx; display: inline-block; }
.risk-tag.low { background: #e8f5e9; color: #2e7d32; }
.risk-tag.medium { background: #fff3e0; color: #e65100; }
.risk-tag.high { background: #fbe9e7; color: #c62828; }
.risk-tag.critical { background: #fce4ec; color: #880e4f; }
.risk-tag.unknown { background: #f5f5f5; color: #666; }
.decision-tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 6rpx; display: inline-block; }
.decision-tag.approve { background: #e8f5e9; color: #2e7d32; }
.decision-tag.deny { background: #fbe9e7; color: #c62828; }
.decision-tag.pause { background: #fff8e1; color: #f57f17; }
.decision-tag.reply { background: #e3f2fd; color: #1565c0; }
.bubble-time { font-size: 20rpx; color: #bbb; display: block; margin-top: 4rpx; }

/* ── Inline action buttons ── */
.action-row { display: flex; gap: 12rpx; margin-top: 14rpx; flex-wrap: wrap; }
.chat-action-btn { flex: 1; min-width: 120rpx; height: 60rpx; line-height: 60rpx; text-align: center; border-radius: 10rpx; font-size: 26rpx; color: #fff; padding: 0; }
.chat-action-btn.approve { background: #07c160; }
.chat-action-btn.deny { background: #e64340; }
.chat-action-btn.pause { background: #ff9800; }

/* ── Inline reply ── */
.reply-inline { display: flex; gap: 10rpx; align-items: center; margin-top: 12rpx; border-top: 1rpx solid #eee; padding-top: 12rpx; }
.inline-reply-input { flex: 1; height: 56rpx; border: 1rpx solid #ddd; border-radius: 8rpx; padding: 0 12rpx; font-size: 24rpx; background: #f8f8f8; }
.inline-reply-btn { height: 56rpx; line-height: 56rpx; background: #07c160; color: #fff; border-radius: 8rpx; font-size: 24rpx; padding: 0 18rpx; flex-shrink: 0; }

/* ── Risk notice (high/critical) ── */
.risk-notice-inline { background: #fff3e0; padding: 12rpx; border-radius: 8rpx; font-size: 22rpx; color: #e65100; text-align: center; margin-top: 10rpx; }

/* ── Bottom input bar ── */
.input-bar { display: flex; gap: 12rpx; align-items: center; padding: 14rpx 24rpx; border-top: 1rpx solid #ddd; background: #f8f8f8; }
.chat-input { flex: 1; height: 64rpx; border: 1rpx solid #ddd; border-radius: 12rpx; padding: 0 16rpx; font-size: 28rpx; background: #fff; }
.send-btn { height: 64rpx; line-height: 64rpx; background: #07c160; color: #fff; border-radius: 12rpx; font-size: 28rpx; padding: 0 32rpx; flex-shrink: 0; }
