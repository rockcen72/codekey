.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--ck-bg);
}

/* ── Topbar ── */

.detail-topbar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 20rpx 24rpx 12rpx;
  background: var(--ck-bg);
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  /* empty button kept for navigation, no visible text */
}

.title-wrap {
  text-align: center;
  min-width: 0;
  max-width: 70%;
}

.detail-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--ck-text);
}

.ws-indicator {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1rpx solid var(--ck-border);
  background: var(--ck-surface);
}

.ws-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--ck-subtle);
  transition: background 140ms ease;
}

.ws-indicator.online .ws-dot {
  background: var(--ck-success);
}

/* ── Timeline ── */

.timeline {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 6rpx 24rpx 24rpx;
}

/* System markers */
.marker-wrap {
  display: flex;
  justify-content: center;
  margin: 16rpx 0;
}

.timeline-marker {
  padding: 8rpx 18rpx;
  max-width: 75%;
  border-radius: var(--ck-radius-full);
  background: var(--ck-border);
  color: var(--ck-muted);
  font-size: 20rpx;
  text-align: center;
}

/* ── User message bubble ── */

.msg-row {
  display: flex;
  margin-bottom: 16rpx;
}

.msg-row.right {
  justify-content: flex-end;
}

.msg-bubble {
  max-width: 80%;
  padding: 14rpx 18rpx;
  border-radius: var(--ck-radius-lg);
  border: 1rpx solid transparent;
}

.msg-bubble.user {
  background: #eef2ff;
  border-color: #c7d6fe;
}

.msg-text {
  display: block;
  color: var(--ck-text);
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}

.msg-time {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--ck-subtle);
  text-align: right;
}

/* ── Agent event cards ── */

.event-card-wrap {
  margin-bottom: 16rpx;
}

.event-card {
  padding: 20rpx;
  border: 1rpx solid var(--ck-border);
  border-radius: var(--ck-radius-md);
  background: var(--ck-surface);
  box-shadow: 0 2rpx 8rpx rgba(28, 25, 23, 0.04);
}

.event-card.pending {
  border-color: #bfdbfe;
  background: #fafbff;
}

.event-card.complete {
  border-color: #bbf7d0;
  background: #fafdf7;
}

.event-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.event-type {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--ck-text);
}

.event-time,
.msg-time {
  font-size: 20rpx;
  color: var(--ck-subtle);
}

.event-summary {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--ck-text);
  line-height: 1.6;
  word-break: break-word;
}

/* Code block (warm dark) */
.code-block {
  max-height: 260rpx;
  overflow: auto;
  padding: 16rpx 18rpx;
  border-radius: var(--ck-radius-sm);
  background: var(--ck-code-bg);
}

.code-block.large {
  max-height: 420rpx;
}

.code-text {
  color: var(--ck-code-text);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Courier New', monospace;
  font-size: 22rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

/* Tags */
.tag-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.risk-tag,
.decision-tag {
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 12rpx;
  border-radius: var(--ck-radius-sm);
  font-size: 22rpx;
  font-weight: 600;
}

.risk-tag.low {
  background: #f0fdf4;
  color: #166534;
}

.risk-tag.medium {
  background: #f5f5f4;
  color: var(--ck-muted);
}

.risk-tag.high,
.risk-tag.critical {
  background: #fef2f2;
  color: #991b1b;
}

.risk-tag.unknown {
  background: #f5f5f4;
  color: var(--ck-subtle);
}

/* Pending pulse indicator */
.pending-pulse {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--ck-warning);
}

.pulse-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--ck-warning);
}

/* Decision tags */
.decision-tag.approve {
  background: #f0fdf4;
  color: #166534;
}

.decision-tag.deny {
  background: #fef2f2;
  color: #991b1b;
}

.decision-tag.pause {
  background: #f5f5f4;
  color: var(--ck-muted);
}

.decision-tag.reply {
  background: #eef2ff;
  color: var(--ck-primary);
}

/* Action buttons */
.action-bar {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.action-btn {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  border-radius: var(--ck-radius-full);
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  transition: background 140ms ease, color 140ms ease;
}

.action-btn.primary {
  background: var(--ck-primary);
  color: #fff;
}

.action-btn.secondary {
  background: transparent;
  color: var(--ck-danger);
  border: 1rpx solid var(--ck-border);
}

.action-btn.ghost {
  background: transparent;
  color: var(--ck-muted);
  border: 1rpx solid var(--ck-border);
}

.action-btn.outline {
  background: transparent;
  color: var(--ck-primary);
  border: 1rpx solid var(--ck-primary);
}

.action-btn:active {
  opacity: 0.8;
}

/* ── Composer: image button + pill input + circular send button ── */

.composer {
  padding: 14rpx 28rpx calc(14rpx + env(safe-area-inset-bottom));
  background: var(--ck-surface);
}

.composer-inner {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
}

.composer-media-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f2f4;
  flex-shrink: 0;
}

.composer-media-btn:active {
  background: #e5e7eb;
}

.media-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid #7a7f87;
  border-radius: 5rpx;
  overflow: hidden;
}

.media-sun {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #7a7f87;
}

.media-mountain {
  position: absolute;
  left: 5rpx;
  bottom: -10rpx;
  width: 22rpx;
  height: 22rpx;
  background: #7a7f87;
  transform: rotate(45deg);
}

.composer-input-wrap {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  border-radius: 999rpx;
  background: #eef0f3;
  overflow: hidden;
}

.composer-input {
  width: 100%;
  height: 68rpx;
  padding: 0 28rpx;
  border: 0;
  background: transparent;
  color: var(--ck-text);
  font-size: 28rpx;
  line-height: 68rpx;
}

.composer-send {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #18191c;
  color: #fff;
  flex-shrink: 0;
  transition: opacity 140ms ease, transform 140ms ease;
}

.send-arrow {
  position: relative;
  width: 26rpx;
  height: 34rpx;
}

.send-arrow-shaft {
  position: absolute;
  left: 11rpx;
  top: 8rpx;
  width: 4rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: #fff;
}

.send-arrow-head {
  position: absolute;
  left: 2rpx;
  top: 2rpx;
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid #fff;
  border-top: 4rpx solid #fff;
  border-radius: 3rpx 0 0 0;
  transform: rotate(45deg);
}

.composer-send.active {
  opacity: 1;
}

.composer-send:active {
  transform: scale(0.96);
}

/* ── Approval bottom sheet ── */

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  background: rgba(28, 25, 23, 0.45);
}

.approval-sheet {
  width: 100%;
  max-height: 86vh;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: var(--ck-radius-xl) var(--ck-radius-xl) 0 0;
  background: var(--ck-surface);
  overflow: auto;
}

.sheet-handle {
  width: 64rpx;
  height: 6rpx;
  margin: 0 auto 22rpx;
  border-radius: 3rpx;
  background: var(--ck-border);
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--ck-text);
}

.sheet-summary {
  display: block;
  margin: 16rpx 0;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ck-text);
}

.risk-notice {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: var(--ck-radius-sm);
  background: #eef2ff;
  color: var(--ck-primary);
  font-size: 24rpx;
}

.sheet-reply {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--ck-border);
}

.sheet-reply-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 16rpx;
  border: 1rpx solid var(--ck-border);
  border-radius: var(--ck-radius-md);
  background: var(--ck-bg);
  color: var(--ck-text);
  font-size: 26rpx;
}

.sheet-reply-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: var(--ck-radius-md);
  background: var(--ck-primary);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.sheet-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.sheet-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: var(--ck-radius-full);
  font-size: 28rpx;
  font-weight: 800;
  transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
}

/* MuxAgent button variant: primary */
.sheet-btn.approve {
  background: var(--ck-primary);
  color: #fff;
}

.sheet-btn.approve:active {
  background: var(--ck-primary-pressed);
}

.sheet-btn.approve.disabled {
  background: var(--ck-border);
  color: var(--ck-subtle);
}

/* MuxAgent button variant: ghost (outlined) */
.sheet-btn.deny,
.sheet-btn.pause {
  background: transparent;
  border: 1rpx solid var(--ck-border);
  color: var(--ck-muted);
}

.sheet-btn.deny:active,
.sheet-btn.pause:active {
  background: #f5f5f4;
  border-color: var(--ck-subtle);
}

/* ── Empty state ── */

.empty {
  padding: 160rpx 40rpx 0;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  color: var(--ck-border);
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ck-text);
}

.empty-text {
  display: block;
  margin-top: 10rpx;
  color: var(--ck-muted);
  font-size: 26rpx;
  line-height: 1.6;
}
