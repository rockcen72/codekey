page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  background: #f8f8f8;
  color: #333;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: none;
  background: none;
}

button::after {
  border: none;
}

scroll-view {
  -webkit-overflow-scrolling: touch;
}
