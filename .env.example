# Example environment file for docker-compose.
#
# Copy this to .env and fill in real values. Do NOT commit .env to git.
# .env is in .gitignore.
#
# Production deployments should inject these via a secret manager
# (Doppler, Vault, AWS Secrets Manager) or systemd EnvironmentFile=.

# PostgreSQL credentials
POSTGRES_USER=codekey
POSTGRES_PASSWORD=changeme
POSTGRES_DB=codekey

# Connection string used by the relay server
DATABASE_URL=postgres://codekey:changeme@postgres:5432/codekey

# Relay server bind config
PORT=3000
HOST=0.0.0.0
