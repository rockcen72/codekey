{
  "name": "@codekey/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate up --migration-file-language ts",
    "test": "vitest run",
    "test:integration": "node -e \"process.env.DATABASE_URL || (console.error('FATAL: DATABASE_URL is required for integration tests'), process.exit(1))\" && vitest run --reporter=verbose --fileParallelism=false"
  },
  "dependencies": {
    "@codekey/shared": "*",
    "@fastify/cors": "^11.0.0",
    "@fastify/websocket": "^11.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "postgres": "^3.4.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "node-pg-migrate": "^7.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
