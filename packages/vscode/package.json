{
  "name": "codekey-vscode",
  "version": "0.2.2",
  "private": true,
  "displayName": "CodeKey",
  "description": "Remote control for AI coding agents — approve, deny, reply from your phone",
  "publisher": "codekey",
  "engines": {
    "vscode": "^1.96.0"
  },
  "type": "module",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codekey.sidebar"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codekey",
          "title": "CodeKey",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codekey": [
        {
          "type": "webview",
          "id": "codekey.sidebar",
          "name": "CodeKey"
        }
      ]
    },
    "commands": [
      {
        "command": "codekey.showDashboard",
        "title": "CodeKey: Show Dashboard"
      },
      {
        "command": "codekey.pairDevice",
        "title": "CodeKey: Pair Device"
      },
      {
        "command": "codekey.startClaudeCode",
        "title": "CodeKey: Start Claude Code"
      },
      {
        "command": "codekey.startCodexSession",
        "title": "CodeKey: Start Codex Session"
      },
      {
        "command": "codekey.enableHook",
        "title": "CodeKey: Enable Hook"
      },
      {
        "command": "codekey.focusSidebar",
        "title": "CodeKey: Focus Sidebar"
      },
      {
        "command": "codekey.enableOpenCode",
        "title": "CodeKey: Enable OpenCode Integration"
      },
      {
        "command": "codekey.startOpenCode",
        "title": "CodeKey: Start OpenCode Terminal"
      },
      {
        "command": "codekey.toggleCodexHook",
        "title": "CodeKey: Toggle Codex Hook"
      },
      {
        "command": "codekey.toggleDebugLog",
        "title": "CodeKey: Toggle Debug Log"
      }
    ],
    "configuration": {
      "title": "CodeKey",
      "properties": {
        "codekey.feishuAppId": {
          "type": "string",
          "default": "",
          "description": "飞书小程序 App ID。配置后配对区域可切换到飞书平台，二维码将使用飞书 AppLink 格式。"
        },
        "codekey.codexExecutable": {
          "type": "string",
          "default": "",
          "description": "Codex CLI 可执行文件的绝对路径。不配置时将依次搜索 PATH 和扩展内置的 codex binary。"
        },
        "codekey.codexInitialPrompt": {
          "type": "string",
          "default": "Analyze the current project structure and provide a summary.",
          "description": "Codex 会话启动时的初始 prompt。"
        },
        "codekey.codexResumeSandbox": {
          "type": "string",
          "default": "workspace-write",
          "enum": ["workspace-write", "read-only", "none"],
          "description": "Codex resume 的 sandbox 模式。workspace-write 可正常读写项目文件；read-only 仅查看；none 不限制（高风险）。"
        },
        "codekey.codexResumeApprovalPolicy": {
          "type": "string",
          "default": "on-request",
          "enum": ["on-request", "never"],
          "description": "Codex resume 的审批策略。on-request 需要审批的命令会暂停等待；never 拒绝所有审批请求（安全模式）。"
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {},
  "devDependencies": {
    "@codekey/shared": "*",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.0"
  }
}
