{
  "name": "codekey-vscode",
  "version": "0.1.0",
  "private": true,
  "displayName": "CodeKey",
  "description": "Remote control for AI coding agents — approve, deny, reply from your phone",
  "publisher": "codekey",
  "engines": {
    "vscode": "^1.96.0"
  },
  "type": "module",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codekey",
          "title": "CodeKey",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codekey": [
        {
          "type": "webview",
          "id": "codekey.sidebar",
          "name": "CodeKey"
        }
      ]
    },
    "commands": [
      {
        "command": "codekey.showDashboard",
        "title": "CodeKey: Show Dashboard"
      },
      {
        "command": "codekey.pairDevice",
        "title": "CodeKey: Pair Device"
      },
      {
        "command": "codekey.startClaudeCode",
        "title": "CodeKey: Start Claude Code"
      },
      {
        "command": "codekey.startCodexSession",
        "title": "CodeKey: Start Codex Session"
      },
      {
        "command": "codekey.enableHook",
        "title": "CodeKey: Enable Hook"
      },
      {
        "command": "codekey.focusSidebar",
        "title": "CodeKey: Focus Sidebar"
      }
    ],
    "configuration": {
      "title": "CodeKey",
      "properties": {
        "codekey.feishuAppId": {
          "type": "string",
          "default": "",
          "description": "飞书小程序 App ID。配置后配对区域可切换到飞书平台，二维码将使用飞书 AppLink 格式。"
        },
        "codekey.codexExecutable": {
          "type": "string",
          "default": "",
          "description": "Codex CLI 可执行文件的绝对路径。不配置时将依次搜索 PATH 和扩展内置的 codex binary。"
        },
        "codekey.codexInitialPrompt": {
          "type": "string",
          "default": "Analyze the current project structure and provide a summary.",
          "description": "Codex 会话启动时的初始 prompt。"
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {},
  "devDependencies": {
    "@codekey/shared": "*",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.0"
  }
}
